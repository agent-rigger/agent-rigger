{
  "$schema": "https://dprint.dev/schemas/v0.json",
  "plugins": [
    "https://plugins.dprint.dev/typescript-0.93.3.wasm",
    "https://plugins.dprint.dev/json-0.19.4.wasm",
    "https://plugins.dprint.dev/markdown-0.17.8.wasm"
  ],
  "typescript": {
    "lineWidth": 100,
    "quoteStyle": "preferSingle",
    "semiColons": "prefer"
  },
  "json": {
    "lineWidth": 100
  },
  "markdown": {
    "lineWidth": 100
  },
  "includes": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.json",
    "**/*.md"
  ],
  "excludes": [
    "**/node_modules/**",
    "**/dist/**",
    "**/coverage/**",
    "bun.lock"
  ]
}
