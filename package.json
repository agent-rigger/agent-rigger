{
  "name": "@agent-rigger/root",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.3.0"
  },
  "workspaces": ["packages/*"],
  "trustedDependencies": ["lefthook", "dprint"],
  "scripts": {
    "lint": "oxlint",
    "format": "dprint fmt",
    "format:check": "dprint check",
    "typecheck": "tsc --noEmit",
    "test": "bun test --pass-with-no-tests",
    "build": "echo \"no package to build yet\"",
    "demo": "bun examples/core-smoke.ts",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@types/bun": "1.3.14",
    "dprint": "0.54.0",
    "lefthook": "2.1.9",
    "oxlint": "1.70.0",
    "typescript": "6.0.3"
  }
}
