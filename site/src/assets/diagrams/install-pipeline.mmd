flowchart TB
  start(["agent-rigger install"]):::process --> fetch
  fetch["fetch<br/>resolveVersion tag→sha<br/>withRemoteCheckout — shallow clone"]:::remote
  fetch --> resolve["resolve<br/>requires · packs — resolver"]:::process
  resolve --> scan["scan<br/>scanEntries — gitleaks / trivy<br/>catalog.json + every resolved entry"]:::process
  scan --> verdict{"scan verdict"}:::gate
  verdict -->|"blocking finding, no --force"| exitScan(["ScanBlockedError<br/>→ exit 1 · nothing written"]):::bad
  verdict -->|"no scanner installed"| warn["warn-only<br/>proceed"]:::warn
  verdict -->|"clean, or --force"| plan
  warn --> plan
  plan["plan (dry-run)<br/>WriteOps preview"]:::process
  plan --> confirm{"confirm?<br/>human"}:::human
  confirm -->|"refuse"| exitRefuse(["no write<br/>→ exit 0"]):::ok
  confirm -->|"approve / --yes"| backup["backup<br/>.bak-* of touched files"]:::process
  backup --> apply["apply<br/>WriteOps"]:::process
  apply --> manifest["manifest<br/>writeManifest → state.json"]:::manifest
  manifest --> done(["installed"]):::ok

