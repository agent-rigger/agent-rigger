flowchart TB
  content["fetched content<br/>cloned checkout"]:::remote --> g1

  g1{"provenance gate<br/>rev-parse HEAD == resolved sha?<br/>fetch.ts"}:::gate
  g1 -->|"mismatch"| x1(["RefShaMismatchError → exit 2<br/>not bypassable by --force"]):::bad
  g1 -->|"match"| g2

  g2{"scan gate<br/>scanEntries — gitleaks / trivy<br/>remote-install.ts"}:::gate
  g2 -->|"blocking finding, no --force"| x2(["ScanBlockedError → exit 1"]):::bad
  g2 -->|"no scanner"| deg["degraded → warn-only<br/>proceed"]:::warn
  g2 -->|"clean, or --force"| g3
  deg --> g3

  g3{"confirmation gate<br/>plan shown · human approves<br/>cmd-install.ts"}:::human
  g3 -->|"refuse"| x3(["no write → exit 0"]):::ok
  g3 -->|"approve"| g4

  g4{"consent gate<br/>tool check commands<br/>consent.json ledger — consent.ts"}:::human
  g4 -->|"refuse"| skip["command not run<br/>tool unverified · install continues"]:::warn
  g4 -->|"approve / already consented"| write
  skip --> write

  write["write to disk<br/>WriteOps + writeManifest"]:::manifest

  force["--force"]:::note
  force -. "covers" .-> g2
  force -. "does NOT cover" .-> g1

  classDef remote fill:#b45309,stroke:#f59e0b,color:#fff
